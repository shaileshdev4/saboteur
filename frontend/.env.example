# Copy to .env.local to override any value (optional)
#   cp .env.example .env.local

# --- API ---
# Dev: use /api (Vite proxies to backend). Prod: full backend URL, no trailing slash.
VITE_API_BASE=/api

# Dev only: where Vite proxies /api (not exposed to browser)
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# --- Dev server ---
VITE_DEV_SERVER_PORT=5173

# --- App ---
VITE_APP_TITLE=The Saboteur
VITE_SESSION_STORAGE_KEY=saboteur_session_id
VITE_DEFAULT_CORRUPT_PROB=0.5
