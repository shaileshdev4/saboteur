# Copy to backend/.env for local dev (never commit .env with real keys).
# On Railway: set these in the service → Variables tab.

# --- SQLite (sessions, rounds, hints, leaderboard cache) ---
# Default if unset: saboteur.sqlite3 in the process working directory.
# Railway: attach a Volume (e.g. mount /data) and use a path on that volume:
SABOTEUR_DB_PATH=/data/saboteur.sqlite3
LLM_CACHE_PATH=/data/llm_cache.json

# --- LLM narration (optional — Groq, OpenAI-compatible) ---
# Without LLM_API_KEY the app uses rule-based step text and library descriptions.
LLM_API_KEY=
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_MODEL=llama-3.3-70b-versatile

# --- Image upload / transcribe (optional) ---
# Only needed for POST /image/transcribe. Groq vision or Mathpix — not required for core game.
MULTIMODAL_API_KEY=
MULTIMODAL_API_BASE=https://api.groq.com/openai/v1
MULTIMODAL_MODEL=llama-3.2-90b-vision-preview
